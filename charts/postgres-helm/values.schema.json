{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "nameOverride": {
      "type": "string"
    },
    "fullnameOverride": {
      "type": "string"
    },
    "commonAnnotations": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "global": {
      "type": "object",
      "properties": {
        "imageRegistry": {
          "type": "string"
        },
        "imagePullSecrets": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "image": {
      "type": "object",
      "properties": {
        "registry": {
          "type": "string"
        },
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "tag": {
          "type": "string",
          "minLength": 1
        },
        "pullPolicy": {
          "type": "string",
          "enum": [
            "Always",
            "IfNotPresent",
            "Never"
          ]
        },
        "pullSecrets": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "repository"
      ],
      "additionalProperties": true
    },
    "replicaCount": {
      "type": "integer",
      "minimum": 1
    },
    "revisionHistoryLimit": {
      "type": "integer",
      "minimum": 0
    },
    "updateStrategy": {
      "type": "object",
      "additionalProperties": true
    },
    "serviceAccount": {
      "type": "object",
      "properties": {
        "create": {
          "type": "boolean"
        },
        "name": {
          "type": "string"
        },
        "annotations": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "automountServiceAccountToken": {
      "type": "boolean"
    },
    "podAnnotations": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "podLabels": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "podSecurityContext": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "runAsUser": {
          "type": "integer",
          "minimum": 0
        },
        "runAsGroup": {
          "type": "integer",
          "minimum": 0
        },
        "fsGroup": {
          "type": "integer",
          "minimum": 0
        },
        "fsGroupChangePolicy": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "securityContext": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "runAsNonRoot": {
          "type": "boolean"
        },
        "runAsUser": {
          "type": "integer",
          "minimum": 0
        },
        "runAsGroup": {
          "type": "integer",
          "minimum": 0
        },
        "allowPrivilegeEscalation": {
          "type": "boolean"
        },
        "readOnlyRootFilesystem": {
          "type": "boolean"
        },
        "capabilities": {
          "type": "object",
          "properties": {
            "drop": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "volumePermissions": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "image": {
          "type": "object",
          "properties": {
            "registry": {
              "type": "string"
            },
            "repository": {
              "type": "string",
              "minLength": 1
            },
            "tag": {
              "type": "string",
              "minLength": 1
            },
            "pullPolicy": {
              "type": "string",
              "enum": [
                "Always",
                "IfNotPresent",
                "Never"
              ]
            }
          },
          "additionalProperties": true
        },
        "command": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "args": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "securityContext": {
          "type": "object",
          "properties": {
            "runAsUser": {
              "type": "integer",
              "minimum": 0
            },
            "runAsGroup": {
              "type": "integer",
              "minimum": 0
            }
          },
          "additionalProperties": true
        },
        "resources": {
          "type": "object",
          "additionalProperties": true
        },
        "extraVolumeMounts": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "priorityClassName": {
      "type": "string"
    },
    "terminationGracePeriodSeconds": {
      "type": "integer",
      "minimum": 0
    },
    "service": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "type": {
          "type": "string"
        },
        "annotations": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "labels": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "ports": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "port": {
                "type": "integer",
                "minimum": 1,
                "maximum": 65535
              },
              "targetPort": {
                "oneOf": [
                  {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 65535
                  },
                  {
                    "type": "string",
                    "minLength": 1
                  }
                ]
              },
              "protocol": {
                "type": "string"
              }
            },
            "required": [
              "name",
              "port",
              "targetPort"
            ],
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": true
    },
    "containerPorts": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "containerPort": {
            "type": "integer",
            "minimum": 1,
            "maximum": 65535
          },
          "protocol": {
            "type": "string"
          }
        },
        "required": [
          "name",
          "containerPort"
        ],
        "additionalProperties": false
      }
    },
    "command": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "args": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "lifecycle": {
      "type": "object",
      "additionalProperties": true
    },
    "env": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "envFrom": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "extraEnvVars": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "extraEnvVarsCM": {
      "type": "string"
    },
    "extraEnvVarsSecret": {
      "type": "string"
    },
    "configMounts": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "extraVolumeMounts": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "extraVolumes": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "initContainers": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "extraContainers": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "resources": {
      "type": "object",
      "additionalProperties": true
    },
    "nodeSelector": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "tolerations": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "affinity": {
      "type": "object",
      "additionalProperties": true
    },
    "topologySpreadConstraints": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "postgres": {
      "type": "object",
      "properties": {
        "database": {
          "type": "string",
          "minLength": 1
        },
        "username": {
          "type": "string",
          "minLength": 1
        },
        "password": {
          "type": "string",
          "minLength": 1
        },
        "pgdata": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "database",
        "username",
        "password",
        "pgdata"
      ],
      "additionalProperties": false
    },
    "auth": {
      "type": "object",
      "properties": {
        "existingSecret": {
          "type": "string"
        },
        "passwordKey": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "passwordKey"
      ],
      "additionalProperties": false
    },
    "probes": {
      "type": "object",
      "properties": {
        "readiness": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "execCommand": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "minItems": 1
            },
            "initialDelaySeconds": {
              "type": "integer",
              "minimum": 0
            },
            "periodSeconds": {
              "type": "integer",
              "minimum": 1
            },
            "timeoutSeconds": {
              "type": "integer",
              "minimum": 1
            },
            "failureThreshold": {
              "type": "integer",
              "minimum": 1
            }
          },
          "required": [
            "enabled",
            "execCommand"
          ],
          "additionalProperties": false
        },
        "liveness": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "execCommand": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "minItems": 1
            },
            "initialDelaySeconds": {
              "type": "integer",
              "minimum": 0
            },
            "periodSeconds": {
              "type": "integer",
              "minimum": 1
            },
            "timeoutSeconds": {
              "type": "integer",
              "minimum": 1
            },
            "failureThreshold": {
              "type": "integer",
              "minimum": 1
            }
          },
          "required": [
            "enabled",
            "execCommand"
          ],
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "persistence": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "size": {
          "type": "string",
          "pattern": "^\\d+(Gi|Mi|Ti)$"
        },
        "accessModes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "volumeClaimTemplateName": {
          "type": "string",
          "minLength": 1
        },
        "mountPath": {
          "type": "string",
          "minLength": 1
        },
        "storageClassName": {
          "type": "string"
        },
        "annotations": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      },
      "required": [
        "enabled",
        "size",
        "accessModes",
        "volumeClaimTemplateName",
        "mountPath"
      ],
      "additionalProperties": false
    },
    "metrics": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "serviceMonitor": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "namespace": {
              "type": "string"
            },
            "interval": {
              "type": "string"
            },
            "scrapeTimeout": {
              "type": "string"
            },
            "honorLabels": {
              "type": "boolean"
            },
            "labels": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              }
            },
            "annotations": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              }
            },
            "relabelings": {
              "type": "array",
              "items": {
                "type": "object"
              }
            },
            "metricRelabelings": {
              "type": "array",
              "items": {
                "type": "object"
              }
            },
            "endpoints": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "port": {
                    "type": "string",
                    "minLength": 1
                  },
                  "path": {
                    "type": "string"
                  },
                  "interval": {
                    "type": "string"
                  },
                  "scrapeTimeout": {
                    "type": "string"
                  }
                },
                "required": [
                  "port"
                ],
                "additionalProperties": false
              }
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    }
  },
  "allOf": [
    {
      "anyOf": [
        {
          "properties": {
            "auth": {
              "properties": {
                "existingSecret": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "required": [
                "existingSecret"
              ]
            }
          }
        },
        {
          "properties": {
            "postgres": {
              "properties": {
                "password": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "required": [
                "password"
              ]
            }
          }
        }
      ],
      "errorMessage": "Either auth.existingSecret or postgres.password must be set"
    }
  ]
}
